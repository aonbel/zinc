    "workflowPresets": [
    {
      "name": "SanCheck",
      "steps": [
        {
          "type": "configure",
          "name": "SanCheck"
        },
        {
          "type": "build",
          "name": "SanCheck"
        },
        {
          "type": "test",
          "name": "SanCheck"
        }
      ]
    },{
      "name": "Debug",
      "steps": [
        {
          "type": "configure",
          "name": "Debug"
        },
        {
          "type": "build",
          "name": "Debug"
        },
        {
          "type": "test",
          "name": "Debug"
        }
      ]
    },{
      "name": "Release",
      "steps": [
        {
          "type": "configure",
          "name": "Release"
        },
        {
          "type": "build",
          "name": "Release"
        },
        {
          "type": "test",
          "name": "Release"
        }
      ]
    }
